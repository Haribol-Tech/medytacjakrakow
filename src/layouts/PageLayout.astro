---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title?: string;
  description?: string;
  pageTitle: string;
  breadcrumb: string;
}

const { title, description, pageTitle, breadcrumb } = Astro.props;
---

<BaseLayout title={title} description={description}>

  <!-- Page Header -->
  <div class="page-hero">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <div class="page-hero-content">
            <div class="section-title">
              <h1 class="text-anime-style-2">{pageTitle}</h1>
            </div>
            <nav aria-label="breadcrumb">
              <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Strona główna</a></li>
                <li class="breadcrumb-item active" aria-current="page">{breadcrumb}</li>
              </ol>
            </nav>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Treść podstrony -->
  <slot />

</BaseLayout>
