---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="O nas — Studio Dźwięku Jogi Kraków"
  description="Stowarzyszenie Studio Dźwięku Jogi w Krakowie. Poznaj naszą historię i misję."
  pageTitle="O nas"
  breadcrumb="O nas"
>

  <div class="about-us">
    <div class="container">
      <div class="row align-items-center">

        <div class="col-lg-6">
          <div class="about-images">
            <div class="about-image">
              <figure>
                <img src="/images/about-us-img.png" alt="Studio Dźwięku Jogi">
              </figure>
            </div>
            <div class="about-image-title">
              <h2>o nas</h2>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="about-us-content">
            <div class="section-title">
              <h3 class="wow fadeInUp">Kim jesteśmy</h3>
              <h2 class="text-anime-style-2">Studio Dźwięku Jogi — <span>medytacja w Krakowie</span></h2>
              <p class="wow fadeInUp" data-wow-delay="0.2s">
                Jesteśmy niekomercyjnym stowarzyszeniem działającym w Krakowie, przy ul. Starowiślnej 20/5.
                Od lat prowadzimy zajęcia medytacji i jogi dostępne dla każdego — niezależnie od wieku i doświadczenia.
              </p>
            </div>
            <div class="about-content-body">
              <div class="about-benefit-item wow fadeInUp" data-wow-delay="0.4s">
                <div class="icon-box">
                  <img src="/images/icon-about-benefit-1.svg" alt="">
                </div>
                <div class="about-benefit-item-content">
                  <h3>Wspólnota i wsparcie</h3>
                  <p>Tworzymy przestrzeń, w której każdy może czuć się mile widziany i rozwijać się we własnym tempie.</p>
                </div>
              </div>
              <div class="about-benefit-item wow fadeInUp" data-wow-delay="0.6s">
                <div class="icon-box">
                  <img src="/images/icon-about-benefit-2.svg" alt="">
                </div>
                <div class="about-benefit-item-content">
                  <h3>Tradycja i doświadczenie</h3>
                  <p>Nasze zajęcia opierają się na autentycznych tradycjach medytacyjnych i jogicznych, przekazywanych z pokolenia na pokolenie.</p>
                </div>
              </div>
            </div>
            <div class="about-content-btn wow fadeInUp" data-wow-delay="0.8s">
              <a href="/stowarzyszenie-studio-dzwieku-jogi/" class="btn-default">Dane stowarzyszenia</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

</PageLayout>
