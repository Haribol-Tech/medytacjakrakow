---
import PageLayout from '../layouts/PageLayout.astro';

const zajecia = [
  {
    href: '/medytacja-od-podstaw/',
    title: 'Medytacja od podstaw',
    opis: 'Dla osób zaczynających przygodę z medytacją. Poznaj techniki uważności, oddech i podstawy praktyki.',
    icon: '/images/icon-service-item-1.svg',
  },
  {
    href: '/joga-dla-kazdego/',
    title: 'Joga dla każdego',
    opis: 'Zajęcia dostosowane do wszystkich poziomów zaawansowania. Praca z ciałem, oddechem i umysłem.',
    icon: '/images/icon-service-item-2.svg',
  },
  {
    href: '/medytacja-kirtan/',
    title: 'Kirtan Medytacja',
    opis: 'Medytacja poprzez śpiew mantr. Praktyka otwierająca serce, dostępna dla każdego.',
    icon: '/images/icon-service-item-3.svg',
  },
  {
    href: '/relaks-i-medytacja/',
    title: 'Relaks i Medytacja',
    opis: 'Głęboki relaks, techniki redukcji napięcia i prowadzone medytacje na wyciszenie.',
    icon: '/images/icon-service-item-4.svg',
  },
  {
    href: '/warsztaty-redukcji-stresu/',
    title: 'Warsztaty Redukcji Stresu',
    opis: 'Praktyczne narzędzia do pracy ze stresem, oparte na tradycji uważności i technikach relaksacyjnych.',
    icon: '/images/icon-service-item-5.svg',
  },
];
---

<PageLayout
  title="Zajęcia medytacji i jogi w Krakowie"
  description="Medytacja od podstaw, joga, kirtan, relaks i warsztaty redukcji stresu. Zajęcia dla każdego w centrum Krakowa."
  pageTitle="Zajęcia"
  breadcrumb="Zajęcia"
>

  <div class="our-services">
    <div class="container">
      <div class="row section-row align-items-center">
        <div class="col-lg-8">
          <div class="section-title">
            <h3 class="wow fadeInUp">Co oferujemy</h3>
            <h2 class="text-anime-style-2">Zajęcia medytacji i jogi <span>w Krakowie</span></h2>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="section-btn wow fadeInUp" data-wow-delay="0.2s">
            <a href="/kalendarz/" class="btn-default">Zobacz grafik</a>
          </div>
        </div>
      </div>

      <div class="row">
        {zajecia.map((z, i) => (
          <div class="col-lg-4 col-md-6">
            <div class="service-item wow fadeInUp" data-wow-delay={`${i * 0.1}s`}>
              <div class="service-header">
                <div class="icon-box">
                  <img src={z.icon} alt="">
                </div>
                <div class="service-btn">
                  <a href={z.href}><img src="/images/arrow-white.svg" alt=""></a>
                </div>
              </div>
              <div class="service-content">
                <h3><a href={z.href}>{z.title}</a></h3>
                <p>{z.opis}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>

</PageLayout>
